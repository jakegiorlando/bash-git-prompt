# This is an alternative approach. mycustom in git repo.
override_git_prompt_colors() {
  GIT_PROMPT_THEME_NAME="mycustom"

  GIT_PROMPT_START_USER="_LAST_COMMAND_INDICATOR_ ${BoldYellow}${PathShort}${ResetColor}"
  GIT_PROMPT_END_USER="${ResetColor} $ "
  GIT_PROMPT_END_ROOT="${BoldRed} #${ResetColor} "
}

reload_git_prompt_colors "mycustom"

